{
  "name": "@nayan9229/identity-resolver",
  "version": "1.0.8",
  "description": "Ultralight OpenRTB identity & consent resolver. Reads browser cookies to assemble user.buyeruid, user.eids[], DEVICE_ID, and GDPR/CCPA signals for programmatic ad bid requests.",
  "keywords": [
    "openrtb",
    "prebid",
    "advertising",
    "programmatic",
    "identity",
    "consent",
    "gdpr",
    "ccpa",
    "uid2",
    "buyeruid",
    "eids",
    "cookie",
    "adtech",
    "pubmatic",
    "ttd",
    "criteo"
  ],
  "homepage": "https://github.com/nayan9229/identity-resolver",
  "bugs": {
    "url": "https://github.com/nayan9229/identity-resolver/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nayan9229/identity-resolver.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.esm.js",
  "browser": "./dist/index.umd.js",
  "unpkg": "./dist/index.umd.js",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs",
      "browser": "./dist/index.umd.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c --watch",
    "test": "node scripts/test.mjs",
    "test:coverage": "node scripts/test.mjs --coverage",
    "test:ci": "node scripts/test.mjs --coverage --ci",
    "test:debug": "node scripts/test.mjs --detectOpenHandles --verbose",
    "lint": "eslint src/**/*.js",
    "size": "size-limit",
    "prepublishOnly": "pnpm run lint && pnpm run test:ci && pnpm run build"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@size-limit/preset-small-lib": "^11.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rollup": "^4.18.0",
    "size-limit": "^11.0.0"
  },
  "size-limit": [
    {
      "path": "./dist/index.umd.js",
      "limit": "3 kB"
    },
    {
      "path": "./dist/index.esm.js",
      "limit": "3 kB"
    }
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}
